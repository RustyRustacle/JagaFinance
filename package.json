{
  "name": "vaultledger",
  "private": true,
  "version": "0.1.0",
  "description": "B2B Receipt & Expense Intelligence Platform",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "turbo --filter=@vaultledger/db generate",
    "db:migrate": "turbo --filter=@vaultledger/db migrate:dev",
    "db:push": "turbo --filter=@vaultledger/db push",
    "db:studio": "turbo --filter=@vaultledger/db studio",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:reset": "docker-compose down -v && docker-compose up -d"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "packageManager": "pnpm@9.5.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
